code:
  bryzek:
    bryzek-apibuilder-spec:
      version: latest
      generators:
        - generator: typescript
          target: ./src/generated
    bryzek-apibuilder:
      version: latest
      generators:
        - generator: typescript
          target: ./src/generated
    bryzek-apibuilder-generator:
      version: latest
      generators:
        - generator: typescript
          target: ./src/generated
    platform:
      version: latest
      generators:
        - generator: typescript
          target: ./src/generated
          attributes:
            - name: "filter"
              value:
                types:
                  - user_reference
                  - person
                resources:
                  - tenant_session
                  - user
                  - phone
    platform-storage:
      version: latest
      generators:
        - generator: typescript
          target: ./src/generated
          attributes:
            - name: "filter"
              value:
                types:
                  - file
    platform-error:
      version: latest
      generators:
        - generator: typescript
          target: ./src/generated
