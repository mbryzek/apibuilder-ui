# API Builder UI Configuration

# API base URL (default: https://api.apibuilder.io)
# VITE_API_BASE_URL=https://api.apibuilder.io

# App base URL (default: http://localhost:5173)
# VITE_APP_BASE_URL=http://localhost:5173

# GitHub OAuth (default client ID is for development)
# VITE_GITHUB_CLIENT_ID=60aafb7d025ff883bcc2
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Environment (development/production)
# VITE_ENVIRONMENT=development
