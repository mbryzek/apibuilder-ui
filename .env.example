# API Builder UI Configuration

# API base URL (default: http://localhost:9001)
# For production: VITE_API_BASE_URL=https://api.apibuilder.io
# VITE_API_BASE_URL=http://localhost:9001

# App base URL (default: http://localhost:5173)
# VITE_APP_BASE_URL=http://localhost:5173

# GitHub OAuth (production only)
# VITE_GITHUB_CLIENT_ID=<your GitHub OAuth app client ID>
# GITHUB_CLIENT_SECRET=<your GitHub OAuth app client secret>

# Environment (development/production)
# VITE_ENVIRONMENT=development
