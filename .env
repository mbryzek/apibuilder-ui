VITE_API_BASE_URL=http://localhost:9300
VITE_TENANT_ID=apibuilder
VITE_APP_BASE_URL=http://localhost:5173
VITE_ENVIRONMENT=development
# VITE_GITHUB_CLIENT_ID=your-dev-github-client-id

# Version stamp: release-sveltekit exports the real PUBLIC_VERSION /
# PUBLIC_RELEASED_AT into the build environment (process env beats .env files);
# these empty defaults just keep non-release builds compiling.
PUBLIC_VERSION=""
PUBLIC_RELEASED_AT=""
